# Server Configuration
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin Email (receives notifications)
ADMIN_EMAIL=ljoy23200@gmail.com

# Optional one-time bootstrap account (for first run only)
# Leave empty to disable automatic admin creation.
ADMIN_BOOTSTRAP_NAME=System Administrator
ADMIN_BOOTSTRAP_PASSWORD=admin123

# For development only. Do not enable in production.
ALLOW_OTP_BYPASS=false

# Gmail Configuration for sending emails
# You need to create an App Password in your Google Account:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create a new app password for "Mail"
# 3. Copy the 16-character password here
GMAIL_USER=ljoy23200@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Dashboard sample fallback (keep false to show only real data)
ALLOW_SAMPLE_DATA=false
